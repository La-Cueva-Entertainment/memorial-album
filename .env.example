# Memorial Scrapbook — Environment Variables

# ─── Required ─────────────────────────────────────────────────────────────────

# Prisma database URL. Uses SQLite by default.
# For production PostgreSQL: postgresql://user:pass@host:5432/dbname
DATABASE_URL="file:./data/dev.db"

# Secret for signing session cookies. Must be >= 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-a-32-char-random-string-before-deploying"

# Admin password (leave empty to disable admin mode entirely)
ADMIN_PASSWORD="change-me"

# ─── Optional ─────────────────────────────────────────────────────────────────

# Site identity (can also be changed in the UI env — here for server-side defaults)
# NEXT_PUBLIC_SITE_NAME="Katherine"
# NEXT_PUBLIC_SITE_DATES="1965 – 2024"
# NEXT_PUBLIC_SITE_ACCENT="#b5704f"

# Max upload size in MB (default: 20)
# MAX_UPLOAD_MB=20
